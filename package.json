{
  "name": "devsecops-ssdlc-demo",
  "version": "1.0.0",
  "description": "Demonstração de aplicação segura integrando DevSecOps, SSDLC e ferramentas de segurança no CI/CD",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "node --check src/server.js",
    "sec:audit": "npm audit",
    "sec:scan-local": "powershell -ExecutionPolicy Bypass -File ./scripts/run-local-security-audit.ps1"
  },
  "keywords": [
    "devsecops",
    "ssdlc",
    "github-actions",
    "sast",
    "sca",
    "trivy",
    "gitleaks",
    "semgrep",
    "sonarqube",
    "snyk"
  ],
  "author": "DevSecOps Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
